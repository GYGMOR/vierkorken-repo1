# Database (MariaDB/MySQL)
# Lokale MySQL Workbench Verbindung
DATABASE_URL="mysql://appuser:Passwort123!@127.0.0.1:3306/vierkorken"

# Alternative Docker Container
# DATABASE_URL="mysql://appuser:Init1234!@mariadb:3306/backend"

# NextAuth / JWT
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET="your-jwt-secret-here"

# Stripe Payment
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Nexi Payment (for future)
NEXI_API_KEY=""
NEXI_MERCHANT_ID=""

# Email (Nodemailer)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@vierkorken.ch"
SMTP_PASSWORD="your-password"
EMAIL_FROM="VIERKORKEN <noreply@vierkorken.ch>"

# Meilisearch
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_MASTER_KEY="your-master-key"

# S3 / Storage
S3_ENDPOINT="https://s3.amazonaws.com"
S3_REGION="eu-central-1"
S3_BUCKET="vierkorken-media"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# Klara Integration
KLARA_API_URL="https://api.klara.ch"
KLARA_API_KEY=""

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="VIERKORKEN"
NEXT_PUBLIC_CURRENCY="CHF"

# Admin
