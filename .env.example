# Database (MariaDB/MySQL)
# Lokale MySQL Workbench Verbindung
DATABASE_URL="mysql://appuser:Passwort123!@127.0.0.1:3306/vierkorken"

# Alternative Docker Container
# DATABASE_URL="mysql://appuser:Init1234!@mariadb:3306/backend"

# NextAuth / JWT
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET="your-jwt-secret-here"

# Stripe Payment
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Nexi Payment (for future)
NEXI_API_KEY=""
NEXI_MERCHANT_ID=""

# Email (Microsoft 365 SMTP via Nodemailer)
# SMTP Login erfolgt immer mit dem Hauptaccount (admin@vierkorken.ch)
# Die Mails werden aber mit dem entsprechenden From: (info@ oder no-reply@) versendet
# Send-As Rechte müssen im Microsoft 365 Admin Center eingerichtet sein
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
SMTP_SECURE="false"  # false für STARTTLS (Port 587), true für SSL (Port 465)
SMTP_USER="admin@vierkorken.ch"
SMTP_PASS="your-password"

# E-Mail Absender (Shared Mailboxes mit Send-As Rechten)
MAIL_FROM_INFO="info@vierkorken.ch"       # Für normale Kommunikation (Newsletter, Bestellungen, etc.)
MAIL_FROM_NOREPLY="no-reply@vierkorken.ch" # Nur für Passwort-Reset / Account Recovery

# Klara Integration
KLARA_API_URL="https://api.klara.ch"
KLARA_API_KEY=""

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="VIERKORKEN"
NEXT_PUBLIC_CURRENCY="CHF"

# Admin
ADMIN_EMAIL="admin@vierkorken.ch"

# Maintenance Mode
# Set to 'true' to enable coming soon / maintenance mode
# Set to 'false' (or remove) to allow normal access
MAINTENANCE_MODE=false
